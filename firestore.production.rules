rules_version = '2';

// COMBINED PRODUCTION RULES — BoletApp + Gustify
// Both apps share the same Firebase project (boletapp-d609f).
// IMPORTANT: Always include BOTH apps' paths when deploying.
// See INC-001 for the incident that motivated this combined file.
//
// Last updated: 2026-03-19
// BoletApp source: firestore.rules
// Gustify source: gustify/firestore.rules

service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================================================
    // BOLETAPP RULES
    // ========================================================================

    // Transaction Access - Owner Only
    match /artifacts/{appId}/users/{userId}/transactions/{transactionId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && hasValidFieldBounds(request.resource.data);
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Field validation for BoletApp transactions
    function hasValidFieldBounds(data) {
      return (!('merchant' in data) || (data.merchant is string && data.merchant.size() >= 1 && data.merchant.size() <= 200))
        && (!('total' in data) || (data.total is number && data.total >= 0 && data.total <= 999999999));
    }

    // Collection Group Query - Denied
    match /{path=**}/transactions/{transactionId} {
      allow read: if false;
    }

    // User Data Isolation (all subcollections: preferences, credits, etc.)
    match /artifacts/{appId}/users/{userId}/{document=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && hasValidFieldBounds(request.resource.data);
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Pending Scans - Async scan pipeline (Story 18-13a)
    // Admin SDK only for create/update (prevents result spoofing)
    // Queries must include where('userId', '==', auth.uid)
    match /pending_scans/{scanId} {
      allow read, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create, update: if false;
    }

    // ========================================================================
    // GUSTIFY RULES
    // ========================================================================

    // User data (pantry, cookedMeals, shoppingList)
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;

      match /pantry/{ingredientId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create, update, delete: if request.auth != null && request.auth.uid == userId;
      }
      match /cookedMeals/{mealId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create, update, delete: if request.auth != null && request.auth.uid == userId;
      }
      match /shoppingList/{listId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create, update, delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Canonical collections (read-only for users, admin-write only)
    match /canonicalIngredients/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /canonicalPreparedFoods/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /recipes/{recipeId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Item mappings (user-creatable, no update/delete)
    match /itemMappings/{hash} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.source is string
        && request.resource.data.source.size() <= 200
        && request.resource.data.canonicalId is string;
      allow update, delete: if false;
    }

    // Unknown items reporting (update restricted to original reporter)
    match /unknownIngredients/{itemId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 200
        && request.resource.data.reportedBy == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.reportedBy == request.auth.uid;
      allow delete: if false;
    }

    match /unknownPreparedFoods/{itemId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 200
        && request.resource.data.reportedBy == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.reportedBy == request.auth.uid;
      allow delete: if false;
    }

    // Rate limiting (admin-only)
    match /rateLimits/{docId} {
      allow read, write: if false;
    }
    match /rateLimitsByIP/{docId} {
      allow read, write: if false;
    }

    // ========================================================================
    // DEFAULT DENY
    // ========================================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
