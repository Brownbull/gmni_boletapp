rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ============================================================================
    // COMBINED STAGING RULES — boletapp-staging
    //
    // !! SHARED BY TWO APPLICATIONS !!
    // This file covers BOTH Boletapp (Gastify) AND Gustify paths.
    // The boletapp-staging Firebase project is shared by both apps.
    //
    // BEFORE DEPLOYING: Ensure rules work for BOTH apps. Changes that
    // remove or break paths for either app will cause "missing or
    // insufficient permissions" errors in the other.
    //
    // Gustify source:  gustify/firestore.staging.rules
    // Boletapp source: boletapp/firestore.staging.rules
    //
    // When EITHER app updates staging rules, the combined file must be
    // re-merged and deployed from ONE canonical location. Currently
    // deployed from Gustify repo:
    //   firebase deploy --only firestore:rules --project boletapp-staging \
    //     --config firebase.staging.json
    //
    // Whitelist: Only approved emails in the allowedEmails collection
    // can access any data. Seed via Boletapp:
    //   npm run staging:seed-whitelist
    // ============================================================================

    // --- Staging Whitelist (Boletapp Story 16-9) ---
    // Only approved test emails can access data. Prevents unauthorized
    // users from creating accounts and accessing staging data.
    function isAllowedStagingUser() {
      return request.auth != null
        && exists(/databases/$(database)/documents/allowedEmails/$(request.auth.token.email));
    }

    // AllowedEmails collection — readable by owner only (for client-side check),
    // writable only via Firebase Console or admin scripts
    match /allowedEmails/{email} {
      allow get: if request.auth != null && request.auth.token.email == email;
      allow list: if false;
      allow write: if false;
    }

    // --- Shared helper functions ---

    // Validate top-level field bounds (Boletapp TD-15b-9 through TD-15b-13)
    function hasValidFieldBounds(data) {
      return (!('merchant' in data) || (data.merchant is string && data.merchant.size() >= 1 && data.merchant.size() <= 200))
        && (!('total' in data) || (data.total is number && data.total >= 0 && data.total <= 999999999));
    }

    // ============================================================================
    // BOLETAPP (Gastify) RULES
    // Source: boletapp/firestore.staging.rules (Epic 16 / TD-16-7)
    // ============================================================================

    // Collection group query deny (Boletapp security)
    match /{path=**}/transactions/{transactionId} {
      allow read: if false;
    }

    // --- Transactions (with field-bounds validation) ---
    match /artifacts/{appId}/users/{userId}/transactions/{transactionId} {
      allow read: if isAllowedStagingUser() && request.auth.uid == userId;
      allow create, update: if isAllowedStagingUser()
        && request.auth.uid == userId
        && hasValidFieldBounds(request.resource.data);
      allow delete: if isAllowedStagingUser() && request.auth.uid == userId;
    }

    // --- Mapping collections (merchant, category, subcategory, item name) ---
    match /artifacts/{appId}/users/{userId}/merchant_mappings/{docId} {
      allow read, write: if isAllowedStagingUser() && request.auth.uid == userId;
    }
    match /artifacts/{appId}/users/{userId}/category_mappings/{docId} {
      allow read, write: if isAllowedStagingUser() && request.auth.uid == userId;
    }
    match /artifacts/{appId}/users/{userId}/subcategory_mappings/{docId} {
      allow read, write: if isAllowedStagingUser() && request.auth.uid == userId;
    }
    match /artifacts/{appId}/users/{userId}/item_name_mappings/{docId} {
      allow read, write: if isAllowedStagingUser() && request.auth.uid == userId;
    }

    // --- Trusted merchants ---
    match /artifacts/{appId}/users/{userId}/trusted_merchants/{docId} {
      allow read, write: if isAllowedStagingUser() && request.auth.uid == userId;
    }

    // --- Airlocks ---
    match /artifacts/{appId}/users/{userId}/airlocks/{docId} {
      allow read, write: if isAllowedStagingUser() && request.auth.uid == userId;
    }

    // --- Personal records ---
    match /artifacts/{appId}/users/{userId}/personalRecords/{docId} {
      allow read, write: if isAllowedStagingUser() && request.auth.uid == userId;
    }

    // --- Notifications ---
    match /artifacts/{appId}/users/{userId}/notifications/{docId} {
      allow read, write: if isAllowedStagingUser() && request.auth.uid == userId;
    }

    // --- Single-document collections (preferences, credits, insightProfile) ---
    match /artifacts/{appId}/users/{userId}/preferences/{docId} {
      allow read, write: if isAllowedStagingUser() && request.auth.uid == userId;
    }
    match /artifacts/{appId}/users/{userId}/credits/{docId} {
      allow read, write: if isAllowedStagingUser() && request.auth.uid == userId;
    }
    match /artifacts/{appId}/users/{userId}/insightProfile/{docId} {
      allow read, write: if isAllowedStagingUser() && request.auth.uid == userId;
    }

    // --- Pending scans (async scan pipeline, Story 18-13a) ---
    // Admin SDK only for create/update. Client can read/delete own scans.
    match /pending_scans/{scanId} {
      allow read: if isAllowedStagingUser() && request.auth.uid == resource.data.userId;
      allow delete: if isAllowedStagingUser() && request.auth.uid == resource.data.userId;
      allow create, update: if false;
    }

    // ============================================================================
    // GUSTIFY RULES
    // Source: gustify/firestore.staging.rules
    // ============================================================================

    // Gustify user profiles and subcollections
    match /users/{userId} {
      allow read: if isAllowedStagingUser() && request.auth.uid == userId;
      allow create, update: if isAllowedStagingUser() && request.auth.uid == userId;
      allow delete: if false;

      match /pantry/{ingredientId} {
        allow read: if isAllowedStagingUser() && request.auth.uid == userId;
        allow create, update, delete: if isAllowedStagingUser() && request.auth.uid == userId;
      }
      match /cookedMeals/{mealId} {
        allow read: if isAllowedStagingUser() && request.auth.uid == userId;
        allow create, update, delete: if isAllowedStagingUser() && request.auth.uid == userId;
      }
      match /shoppingList/{listId} {
        allow read: if isAllowedStagingUser() && request.auth.uid == userId;
        allow create, update, delete: if isAllowedStagingUser() && request.auth.uid == userId;
      }
    }

    // Canonical ingredients dictionary (read-only)
    match /canonicalIngredients/{id} {
      allow read: if isAllowedStagingUser();
      allow write: if false;
    }

    // Item mappings (Gastify items → canonical ingredients)
    match /itemMappings/{hash} {
      allow read: if isAllowedStagingUser();
      allow create: if isAllowedStagingUser()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.source is string
        && request.resource.data.source.size() <= 200
        && request.resource.data.canonicalId is string;
      allow update, delete: if false;
    }

    // Recipes (read-only)
    match /recipes/{recipeId} {
      allow read: if isAllowedStagingUser();
      allow write: if false;
    }

    // Canonical prepared foods dictionary (read-only)
    match /canonicalPreparedFoods/{id} {
      allow read: if isAllowedStagingUser();
      allow write: if false;
    }

    // Unknown ingredients tracking (community crowdsource)
    match /unknownIngredients/{itemId} {
      allow read: if isAllowedStagingUser();
      allow create: if isAllowedStagingUser()
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 200
        && request.resource.data.reportedBy == request.auth.uid;
      allow update: if isAllowedStagingUser();
      allow delete: if false;
    }

    // Unknown prepared foods tracking (community crowdsource)
    match /unknownPreparedFoods/{itemId} {
      allow read: if isAllowedStagingUser();
      allow create: if isAllowedStagingUser()
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 200
        && request.resource.data.reportedBy == request.auth.uid;
      allow update: if isAllowedStagingUser();
      allow delete: if false;
    }

    // ============================================================================
    // Scan Fixtures - Admin SDK only (Plan B, M2)
    // Used by fixture-based staging testing. No client access ever —
    // fixtures are seeded via admin scripts only.
    // ============================================================================
    match /scan_fixtures/{fixtureId} {
      allow read, write: if false;
    }

    // ============================================================================
    // DEFAULT DENY — All other paths
    // ============================================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}