rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ============================================================================
    // Transaction Access - Owner Only
    // Simplified after Epic 14c-refactor: Cross-user shared group access removed
    // ============================================================================
    match /artifacts/{appId}/users/{userId}/transactions/{transactionId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      // Validate top-level field lengths on create/update (TD-15b-9)
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && isValidTransactionWrite(request.resource.data);
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Validate top-level transaction field types/lengths on write (TD-15b-9, TD-15b-11).
    //
    // Scope of enforcement:
    // - merchant field: string, max 200 chars
    // - total field: must be numeric type if present
    // - Other scalars (date, category): type enforcement at client layer (sanitize.ts);
    //   string-length validation would require knowing exact max values — tracked as future work.
    // - items[].name / items[].subcategory: NOT validated here — Firestore rules cannot
    //   iterate list elements to check per-item field lengths. Item-level length enforcement
    //   is handled at the client layer via sanitizeItemName(200)/sanitizeSubcategory(100)
    //   in sanitize.ts and inline sanitizeInput(100/50) in EditViewItemsSection.tsx.
    //   Server-side items[] enforcement options evaluated in TD-15b-11 Dev Notes —
    //   all options exceed story budget; tracked as future work.
    //
    // Architectural note (TD-15b-11): This function uses optional field guards so it returns
    // true for documents that lack merchant/total fields (preferences, credits, etc.).
    // The catch-all user-data rule below also calls this function on create/update, which
    // closes the bypass that previously allowed invalid transaction writes via the wildcard.
    function isValidTransactionWrite(data) {
      return (!('merchant' in data) || (data.merchant is string && data.merchant.size() <= 200))
        && (!('total' in data) || data.total is number);
    }

    // ============================================================================
    // Collection Group Query - Denied
    // Client-side collection group queries disabled for security (2026-01-17)
    // ============================================================================
    match /{path=**}/transactions/{transactionId} {
      allow read: if false;
    }

    // ============================================================================
    // User Data Isolation
    // Each user can only access their own data (all subcollections).
    // create/update requires isValidTransactionWrite to close the catch-all bypass
    // (TD-15b-11). The function returns true for non-transaction documents (no
    // merchant/total fields), so preferences, credits, and other subcollections are
    // unaffected. delete is auth-only (request.resource is null on delete — same
    // pattern as the transaction-specific rule above).
    // ============================================================================
    match /artifacts/{appId}/users/{userId}/{document=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && isValidTransactionWrite(request.resource.data);
      allow delete: if request.auth != null && request.auth.uid == userId;
    }


    // ============================================================================
    // Default Deny - All other paths
    // ============================================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
